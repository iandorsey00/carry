{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://carry.iandorsey.com/schema/carry-lesson-v1.schema.json",
  "title": "Carry Lesson Specification v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["spec", "id", "subject", "section", "topic", "title", "learn", "practice"],
  "properties": {
    "$schema": { "type": "string" },
    "spec": { "const": "carry.lesson/v1" },
    "id": { "$ref": "#/$defs/identifier" },
    "subject": { "$ref": "#/$defs/plainText" },
    "section": { "$ref": "#/$defs/identifier" },
    "topic": { "$ref": "#/$defs/plainText" },
    "title": { "$ref": "#/$defs/plainText" },
    "objectives": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/plainText" }
    },
    "requires": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/identifier" }
    },
    "teaches": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/identifier" }
    },
    "registration": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind"],
          "properties": { "kind": { "const": "section" } }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "key"],
          "properties": {
            "kind": { "const": "long-operation" },
            "key": { "$ref": "#/$defs/plainText" }
          }
        }
      ]
    },
    "learn": { "$ref": "#/$defs/learn" },
    "practice": { "$ref": "#/$defs/practice" }
  },
  "$defs": {
    "plainText": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[^<>]+$"
    },
    "mathSource": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[^<>]+$"
    },
    "identifier": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:[.-][a-z0-9]+)*$"
    },
    "textRun": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["text"],
          "properties": { "text": { "$ref": "#/$defs/plainText" } }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["math"],
          "properties": { "math": { "$ref": "#/$defs/mathSource" } }
        }
      ]
    },
    "contentBlock": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "runs"],
          "properties": {
            "type": { "const": "paragraph" },
            "runs": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/textRun" } }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "tex"],
          "properties": {
            "type": { "const": "math" },
            "tex": { "$ref": "#/$defs/mathSource" }
          }
        }
      ]
    },
    "learn": {
      "type": "object",
      "additionalProperties": false,
      "required": ["core"],
      "properties": {
        "figure": {
          "type": "object",
          "additionalProperties": false,
          "required": ["renderer", "id", "caption"],
          "properties": {
            "renderer": { "const": "carry" },
            "id": { "$ref": "#/$defs/identifier" },
            "caption": { "$ref": "#/$defs/plainText" },
            "params": {
              "type": "object",
              "additionalProperties": {
                "oneOf": [
                  { "$ref": "#/$defs/mathSource" },
                  { "type": "number" },
                  { "type": "boolean" }
                ]
              }
            }
          }
        },
        "core": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/contentBlock" } },
        "workedExample": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["math", "note"],
            "properties": {
              "math": { "$ref": "#/$defs/mathSource" },
              "note": { "$ref": "#/$defs/contentBlock" }
            }
          }
        },
        "studio": { "type": "array", "items": { "$ref": "#/$defs/contentBlock" } },
        "applications": { "type": "array", "items": { "$ref": "#/$defs/contentBlock" } },
        "notice": { "type": "array", "items": { "$ref": "#/$defs/contentBlock" } },
        "workspace": { "type": "array", "items": { "$ref": "#/$defs/contentBlock" } }
      }
    },
    "response": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "entry", "traversal"],
      "properties": {
        "kind": { "enum": ["matrix", "digit-grid", "derivation", "transformation"] },
        "entry": { "enum": ["number", "expression"] },
        "traversal": { "enum": ["row-major", "column-major", "guided"] }
      }
    },
    "matrix": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "array",
        "minItems": 1,
        "items": { "type": "number" }
      }
    },
    "fixedSide": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "math"],
      "properties": {
        "kind": { "const": "fixed" },
        "math": { "$ref": "#/$defs/mathSource" }
      }
    },
    "slotSide": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "response", "expected", "hint", "label"],
      "properties": {
        "kind": { "const": "slot" },
        "response": { "const": "expression" },
        "expected": { "$ref": "#/$defs/mathSource" },
        "accepted": { "type": "array", "uniqueItems": true, "items": { "$ref": "#/$defs/mathSource" } },
        "display": { "$ref": "#/$defs/mathSource" },
        "hint": { "$ref": "#/$defs/hint" },
        "misconceptions": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/misconception" }
        },
        "label": { "$ref": "#/$defs/plainText" },
        "placeholder": { "$ref": "#/$defs/plainText" }
      }
    },
    "hint": {
      "oneOf": [
        { "$ref": "#/$defs/plainText" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["level1"],
          "properties": {
            "level1": { "$ref": "#/$defs/plainText" },
            "level2": { "$ref": "#/$defs/plainText" },
            "level3": { "$ref": "#/$defs/plainText" }
          },
          "dependentRequired": { "level3": ["level2"] }
        }
      ]
    },
    "misconception": {
      "type": "object",
      "additionalProperties": false,
      "required": ["matches", "feedback"],
      "properties": {
        "matches": { "$ref": "#/$defs/mathSource" },
        "feedback": { "$ref": "#/$defs/plainText" }
      }
    },
    "transformation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["operation", "from", "to"],
      "properties": {
        "operation": { "$ref": "#/$defs/identifier" },
        "from": { "$ref": "#/$defs/identifier" },
        "to": { "$ref": "#/$defs/identifier" }
      }
    },
    "derivationRow": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "label", "left", "relation", "right"],
      "properties": {
        "id": { "$ref": "#/$defs/identifier" },
        "label": { "$ref": "#/$defs/plainText" },
        "left": { "oneOf": [{ "$ref": "#/$defs/fixedSide" }, { "$ref": "#/$defs/slotSide" }] },
        "relation": { "$ref": "#/$defs/mathSource" },
        "right": { "oneOf": [{ "$ref": "#/$defs/fixedSide" }, { "$ref": "#/$defs/slotSide" }] }
      }
    },
    "problem": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "prompt", "givens"],
      "properties": {
        "id": { "$ref": "#/$defs/identifier" },
        "prompt": { "$ref": "#/$defs/contentBlock" },
        "difficulty": {
          "oneOf": [
            { "type": "integer", "minimum": 1, "maximum": 5 },
            { "enum": ["introductory", "developing", "challenging"] }
          ]
        },
        "transformations": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/transformation" }
        },
        "givens": {
          "oneOf": [
            {
              "type": "object",
              "additionalProperties": false,
              "required": ["operation", "left", "right"],
              "properties": {
                "operation": { "enum": ["add", "subtract", "multiply"] },
                "left": { "$ref": "#/$defs/matrix" },
                "right": { "$ref": "#/$defs/matrix" }
              }
            },
            {
              "type": "object",
              "additionalProperties": false,
              "required": ["top", "bottom"],
              "properties": {
                "top": { "type": "integer", "minimum": 0, "maximum": 999 },
                "bottom": { "type": "integer", "minimum": 0, "maximum": 999 }
              }
            },
            {
              "type": "object",
              "additionalProperties": false,
              "required": ["rows"],
              "properties": {
                "rows": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/derivationRow" } }
              }
            }
          ]
        }
      }
    },
    "practice": {
      "type": "object",
      "additionalProperties": false,
      "required": ["engine", "response", "problems"],
      "properties": {
        "engine": { "enum": ["matrix-operation", "long-addition", "guided-derivation", "equation-transform"] },
        "response": { "$ref": "#/$defs/response" },
        "problems": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/problem" } }
      },
      "allOf": [
        {
          "oneOf": [
            {
              "properties": {
                "engine": { "const": "matrix-operation" },
                "response": { "properties": { "kind": { "const": "matrix" } } }
              }
            },
            {
              "properties": {
                "engine": { "const": "long-addition" },
                "response": { "properties": { "kind": { "const": "digit-grid" } } }
              }
            },
            {
              "properties": {
                "engine": { "const": "guided-derivation" },
                "response": { "properties": { "kind": { "const": "derivation" } } }
              }
            },
            {
              "properties": {
                "engine": { "const": "equation-transform" },
                "response": { "properties": { "kind": { "const": "transformation" } } }
              }
            }
          ]
        },
        {
          "if": {
            "properties": { "engine": { "const": "equation-transform" } }
          },
          "then": {
            "properties": {
              "problems": { "items": { "required": ["transformations"] } }
            }
          },
          "else": {
            "properties": {
              "problems": {
                "items": { "not": { "required": ["transformations"] } }
              }
            }
          }
        }
      ]
    }
  }
}
